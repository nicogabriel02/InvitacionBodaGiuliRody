---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Countdown from '../components/Countdown.astro';
import Details from '../components/Details.astro';
import Carousel from '../components/Carousel.astro';
import RSVP from '../components/RSVP.astro';
import AudioPlayer from '../components/AudioPlayer.astro';
---

<Layout title="Meli y Agus - Nos Casamos">
	<AudioPlayer />
	<Hero />
	<Countdown />
	<Details />
	<Carousel />
	<RSVP />
    
    <footer class="bg-boda-navy text-white text-center py-6 font-sans text-xs tracking-widest opacity-90">
        <p>CONSTRUIDO CON AMOR PARA MELI Y AGUS</p>
    </footer>
</Layout>
