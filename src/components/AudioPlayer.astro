---
---

<div class="fixed bottom-6 left-6 z-50">
    <div class="relative">
        <div id="audio-glow" class="absolute inset-0 bg-boda-brown rounded-full animate-ping opacity-75"></div>
        <button id="audio-control" class="relative bg-boda-brown text-white w-14 h-14 rounded-full flex items-center justify-center shadow-2xl hover:bg-boda-navy transition-all duration-300 hover:scale-110">
            <svg id="play-icon" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z" />
            </svg>
            <svg id="pause-icon" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 hidden" fill="currentColor" viewBox="0 0 24 24">
                <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z" />
            </svg>
        </button>
    </div>
    <audio id="bg-audio" loop>
        <source src="/perfect-ed-sheeran.mp3" type="audio/mpeg">
        Tu navegador no soporta el elemento de audio.
    </audio>
</div>

<script>
    const audioControl = document.getElementById('audio-control');
    const audio = document.getElementById('bg-audio') as HTMLAudioElement;
    const playIcon = document.getElementById('play-icon');
    const pauseIcon = document.getElementById('pause-icon');
    const audioGlow = document.getElementById('audio-glow');

    let isPlaying = false;

    if (audioControl && audio && playIcon && pauseIcon) {
        audioControl.addEventListener('click', () => {
            if (isPlaying) {
                audio.pause();
                playIcon.classList.remove('hidden');
                pauseIcon.classList.add('hidden');
                if (audioGlow) audioGlow.classList.remove('hidden');
            } else {
                audio.play();
                playIcon.classList.add('hidden');
                pauseIcon.classList.remove('hidden');
                if (audioGlow) audioGlow.classList.add('hidden');
            }
            isPlaying = !isPlaying;
        });
    }
</script>
