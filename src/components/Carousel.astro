---
const images = [
    '/IMG_0292.jpeg',
    '/IMG_0293.jpeg',
    '/IMG_0295.jpeg',
    '/IMG_0296.jpeg',
    '/IMG_0297.jpeg',
    '/IMG_0298.jpeg',
    '/IMG_8288.jpg',
    '/IMG_8486.jpg'
];
---

<section class="py-24 bg-boda-ivory overflow-hidden">
    <div class="container mx-auto px-4 mb-12 text-center reveal">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto text-boda-brown mb-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <h3 class="font-serif text-4xl text-boda-brown">Nuestros Momentos</h3>
    </div>

    <!-- Carousel Container -->
    <div class="relative w-full max-w-6xl mx-auto px-4 reveal delay-100">
        <div id="carousel" class="flex gap-4 overflow-x-auto snap-x snap-mandatory scrollbar-hide pb-8 pt-4">
            {images.map((src, index) => (
                <div class="flex-none w-80 md:w-96 aspect-[4/5] snap-center rounded-2xl overflow-hidden shadow-xl shrink-0">
                    <img src={src} alt={`Momento ${index + 1}`} class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" loading="lazy" />
                </div>
            ))}
        </div>
        
        <!-- Controls -->
        <div class="flex justify-center gap-4 mt-4">
            <button id="prevBtn" class="p-3 rounded-full bg-boda-brown text-white hover:bg-boda-navy transition-colors shadow-md">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                </svg>
            </button>
            <button id="nextBtn" class="p-3 rounded-full bg-boda-brown text-white hover:bg-boda-navy transition-colors shadow-md">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
            </button>
        </div>
    </div>
</section>

<style>
    /* Hide scrollbar for Chrome, Safari and Opera */
    .scrollbar-hide::-webkit-scrollbar {
        display: none;
    }
    /* Hide scrollbar for IE, Edge and Firefox */
    .scrollbar-hide {
        -ms-overflow-style: none;  /* IE and Edge */
        scrollbar-width: none;  /* Firefox */
    }
</style>

<script>
    const carousel = document.getElementById('carousel');
    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');

    if (carousel && prevBtn && nextBtn) {
        const scrollAmount = 350; // approximate width of one card + gap

        nextBtn.addEventListener('click', () => {
            carousel.scrollBy({ left: scrollAmount, behavior: 'smooth' });
        });

        prevBtn.addEventListener('click', () => {
            carousel.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
        });
    }
</script>
