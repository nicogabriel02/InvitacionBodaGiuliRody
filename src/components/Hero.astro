---

---

<section
    class="relative w-full h-screen flex items-center justify-center overflow-hidden"
>
    <!-- Background Image -->
    <div class="absolute inset-0 z-0 bg-boda-beige">
        <img
            src="/IMG_0292.jpeg"
            alt="Fondo Giuli y Rody"
            class="w-full h-full object-cover opacity-90 animate-hero-bg"
        />
        <!-- Gradient Overlay for readability -->
        <div
            class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-boda-ivory/80"
        >
        </div>
    </div>

    <!-- Content -->
    <div
        class="relative z-10 text-center px-6 py-6 md:px-8 md:py-8 flex flex-col items-center animate-fade-in-up bg-white/40 backdrop-blur-md rounded-3xl border border-white/30 shadow-2xl mx-4 max-w-xl mt-56 md:mt-80"
    >
        <p
            class="font-sans text-[10px] md:text-xs tracking-[0.3em] uppercase text-boda-navy mb-2 font-semibold"
        >
            Nos Casamos
        </p>
        <h1
            class="font-cursive text-5xl md:text-7xl text-boda-brown mb-3 drop-shadow-md"
        >
            Giuli & Rody
        </h1>
        <div class="w-16 h-px bg-boda-navy/40 mb-4"></div>
        <p class="font-serif italic text-base md:text-lg text-boda-navy font-medium drop-shadow-sm">
            ¡Estás invitado a celebrar con nosotros!
        </p>
    </div>

    <!-- Scroll Indicator -->
    <div
        class="absolute bottom-10 left-1/2 transform -translate-x-1/2 z-10 animate-bounce"
    >
        <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-8 w-8 text-boda-brown"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
        >
            <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
    </div>
</section>

<style>
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    .animate-fade-in-up {
        animation: fadeInUp 1.5s cubic-bezier(0.5, 0, 0, 1) forwards;
    }
    
    @keyframes heroBgZoom {
        0% { transform: scale(1.05); }
        100% { transform: scale(1); }
    }
    .animate-hero-bg {
        animation: heroBgZoom 4s cubic-bezier(0.2, 0, 0, 1) forwards;
    }
</style>
