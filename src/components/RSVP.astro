<section class="py-24 bg-boda-beige/30 text-center">
    <div class="container mx-auto px-4 max-w-3xl">
        <!-- Dress Code -->
        <div class="mb-20 reveal">
            <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-12 w-12 mx-auto text-boda-brown mb-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path>
            </svg>
            <h3 class="font-serif text-3xl text-boda-navy mb-4">Dress Code</h3>
            <p
                class="font-sans text-boda-navy/80 tracking-widest uppercase text-sm mb-2"
            >
                Semi formal garden party, calzado cómodo y lo más importante: el
                mate 🧉
            </p>
            <p class="font-sans text-boda-navy mb-6">
                Queremos que te sientas cómodo, pero acordate que es una noche
                especial.
            </p>
            <a
                href="https://pin.it/3CeWVmde6"
                target="_blank"
                class="inline-block px-6 py-2 border border-boda-navy text-boda-navy hover:bg-boda-navy hover:text-white rounded-full font-sans text-xs tracking-widest transition-colors shadow-sm"
            >
                VER INSPIRACIÓN EN PINTEREST
            </a>
        </div>

        <!-- Tarjeta -->
        <div class="mb-20 reveal delay-100">
            <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-12 w-12 mx-auto text-boda-brown mb-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"
                ></path>
            </svg>
            <h3 class="font-serif text-3xl text-boda-navy mb-4">Tarjeta</h3>
            <p class="font-sans text-boda-navy mb-6">
                Para disfrutar juntos esta celebración el valor de la tarjeta es
                de 65 usd. Precio válido hasta el 14 de noviembre. Luego hasta
                el 31 de enero el valor será de 70 usd.
            </p>

            <div
                class="bg-white/80 p-6 rounded-xl text-left max-w-md mx-auto shadow-sm border border-boda-brown/20 space-y-3 font-sans text-boda-navy mb-8"
            >
                <p><strong>Titular:</strong> Giulieta Ariana Ciuffardi Lemos</p>
                <p>
                    <strong>Alias:</strong>
                    <span class="font-mono bg-boda-beige/50 px-2 py-1 rounded cursor-pointer copy-text hover:bg-boda-beige transition-colors" data-copy="casamiento.giu.ro" title="Click para copiar"
                        >casamiento.giu.ro</span
                    >
                </p>
                <p>
                    <strong>CBU:</strong>
                    <span class="font-mono text-sm cursor-pointer copy-text bg-boda-beige/50 px-2 py-1 rounded hover:bg-boda-beige transition-colors" data-copy="1430001713042921950019" title="Click para copiar">1430001713042921950019</span
                    >
                </p>
                <p><strong>CUIL:</strong> 27-44977799-4</p>
                <p><strong>Celular:</strong> +5493434159643</p>
            </div>
        </div>

        <!-- Regalos -->
        <div class="mb-20 reveal delay-200">
            <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-12 w-12 mx-auto text-boda-brown mb-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"
                ></path>
            </svg>
            <h3 class="font-serif text-3xl text-boda-navy mb-4">Regalos</h3>
            <p
                class="font-sans text-boda-navy max-w-2xl mx-auto leading-relaxed"
            >
                “Lo más importante para nosotros es compartir este día con vos.
                Si querés hacernos un regalo, podés elegir algo de nuestra lista
                para el hogar o colaborar con nuestra luna de miel mediante una
                transferencia. ¡Gracias por acompañarnos en esta nueva etapa!
                ✨”
            </p>
        </div>

        <!-- Asistencia -->
        <div
            class="bg-white p-8 md:p-12 rounded-2xl shadow-xl reveal-scale delay-300"
        >
            <h3 class="font-serif text-4xl text-boda-brown mb-6">Asistencia</h3>
            <p class="font-sans text-boda-navy mb-8">
                Por favor, confirmanos tu asistencia antes del 1 de Septiembre
                para ayudarnos con la organización.
            </p>
            <a
                href="#"
                class="btn-magnetic inline-block w-full md:w-auto px-10 py-4 bg-boda-brown text-white rounded-full font-sans text-sm tracking-widest hover:bg-boda-navy transition-colors shadow-md"
            >
                CONFIRMAR ASISTENCIA
            </a>
        </div>
    </div>
    
    <!-- Toast Notification -->
    <div id="toast" class="fixed bottom-24 left-1/2 transform -translate-x-1/2 bg-boda-navy text-white px-6 py-3 rounded-full font-sans text-sm shadow-xl opacity-0 pointer-events-none transition-opacity duration-300 z-50">
        ¡Copiado al portapapeles!
    </div>
</section>

<script>
    // Copy to clipboard logic
    const copyElements = document.querySelectorAll('.copy-text');
    const toast = document.getElementById('toast');

    copyElements.forEach(el => {
        el.addEventListener('click', async () => {
            const textToCopy = el.getAttribute('data-copy');
            if (textToCopy) {
                try {
                    await navigator.clipboard.writeText(textToCopy);
                    if (toast) {
                        toast.classList.remove('opacity-0');
                        toast.classList.add('opacity-100');
                        setTimeout(() => {
                            toast.classList.remove('opacity-100');
                            toast.classList.add('opacity-0');
                        }, 2000);
                    }
                } catch (err) {
                    console.error('Error al copiar:', err);
                }
            }
        });
    });

</script>
